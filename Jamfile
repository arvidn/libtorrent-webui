import modules ;
import feature : feature ;

BOOST_ROOT = [ modules.peek : BOOST_ROOT ] ;

feature pam : off on : composite ;

feature use-boost : system source : composite ;

project libtorrent-webui : requirements <cxxstd>17 ;

use-project /torrent : libtorrent ;
lib sqlite : : <name>sqlite3 <search>/opt/local/lib : <include>/opt/local/include ;

if $(BOOST_ROOT)
{
	use-project /boost : $(BOOST_ROOT) ;
}

SOURCES =
	webui
	libtorrent_webui
	json_util
	file_downloader
	mime_type
	torrent_post
	disk_space
	base64
	escape_json
	auto_load
	save_settings
	save_resume
	torrent_history
	piece_history
	auth
	no_auth
	load_config
	error_logger
	websocket_conn
	alert_handler
	file_requests
	stats_logging
	serve_files
	hex
	utorrent_webui
	file_history
	;

lib torrent-webui
	: # sources
	src/$(SOURCES).cpp src/jsmn.c src/cdecode.c

	: # requirements
	<library>/torrent//torrent
	<library>zlib
	<library>sqlite
	<pam>on:<library>pam
	<pam>on:<source>src/pam_auth.cpp
	<define>USE_WEBSOCKET=1

	: # default build
	<link>static
	<cxxstd>17

	: # usage-requirements
	<include>src
	<target-os>linux:<library>pthread
	<target-os>linux:<library>rt
	<target-os>linux:<library>dynamic-linker
	;

lib zlib : : <name>z <search>/usr/local/lib ;
lib pthread : : <name>pthread <search>/usr/local/lib <link>shared ;
lib rt : : <name>rt <search>/usr/local/lib <link>shared ;
lib pam : : <name>pam <search>/usr/local/lib ;
lib dynamic-linker : : <name>dl <link>shared ;

exe webui_test : test.cpp : <library>torrent-webui <library>/torrent//torrent <cxxstd>17 ;
install stage_webui_test : webui_test : <location>. ;

exe add_user : tools/add_user.cpp : <library>torrent-webui <library>/torrent//torrent <cxxstd>17 ;
install stage_add_user : add_user : <location>. ;

